---
import { getFilters } from '@/api/filters.api.ts';
import { DEFAULT_FILTER } from '@/constants/filters.ts';
import { PAGE_LIMIT } from '@/constants/patterns.ts';
import { renderCategoryCard } from '@/components/category-card/render-category-card.ts';

interface CategoryItem {
  name?: unknown;
  filter?: unknown;
  imgURL?: unknown;
}

let categories: CategoryItem[] = [];
let totalPages = 1;

try {
  const data = await getFilters({
    filter: DEFAULT_FILTER,
    page: 1,
    limit: PAGE_LIMIT.CATEGORIES,
  });

  categories = data.results;
  totalPages = data.totalPages;
} catch {}

const html = categories
  .map((item) =>
    renderCategoryCard({
      name: String(item.name ?? ''),
      filter: String(item.filter ?? ''),
      imgURL: String(item.imgURL ?? ''),
      caption: DEFAULT_FILTER,
    }),
  )
  .join('');
---

<ul
  class="category-list"
  data-component="category-list"
  data-hydrated="false"
  data-total-pages={String(totalPages)}
  aria-live="polite"
  set:html={html}
/>

<script>
  import { initCategoryList } from './category-list.client.ts';

  initCategoryList(document.querySelector('[data-component="category-list"]'));
</script>
