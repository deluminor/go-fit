---
import { DEFAULT_FILTER } from '@/constants/filters.ts';
import { renderFiltersMarkup } from './render-filters.ts';
---

<section
  class="filters"
  data-component="filters"
  aria-label="Exercise filters"
  set:html={renderFiltersMarkup(DEFAULT_FILTER)}
/>

<script>
  import { initFilters } from './filters.client.ts';

  initFilters(document.querySelector('[data-component="filters"]'));
</script>
